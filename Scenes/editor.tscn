[sub_resource type="GDScript" id="GDScript_3lyd6"]
resource_name = "textEditPopup"
script/source = "class_name textEditPopup extends Control

@onready var lineEdit: LineEdit = $PanelContainer/MarginContainer/VBoxContainer/LineEditContainer/LineEdit

@onready var label: Label = $PanelContainer/MarginContainer/VBoxContainer/Label

#need these containers to change their visibility
@onready var cancelButtonContainer: MarginContainer = $PanelContainer/MarginContainer/VBoxContainer/MarginContainer2/HBoxContainer/cancelButtonContainer
@onready var lineEditContainer: MarginContainer = $PanelContainer/MarginContainer/VBoxContainer/LineEditContainer

##true if the prompt requires text input
var withInput=false
##usage example
#func _input(event: InputEvent) -> void:
	#if event.is_action_pressed(\"9\"):
		#signalBus.startTextEditPopup.emit('what a doozy eh?')
		#var inputText = await signalBus.endTextEditPopup
		#print(inputText[0])

func _ready() -> void:
	signalBus.startTextEditPopup.connect(startInputPopup)
	signalBus.startTextPopup.connect(startInfoPopup)

##Just text and a confirm button as a notification.
func startInfoPopup(prompt:String):
	withInput = false
	lineEditContainer.visible = false
	cancelButtonContainer.visible = false
	visible = true
	label.text = prompt
	globalEditor.textPopupIsOpen = true

func startInputPopup(prompt:String):
	withInput = true
	lineEdit.clear()
	lineEditContainer.visible = true
	cancelButtonContainer.visible = true
	visible = true
	label.text = prompt
	globalEditor.textPopupIsOpen = true
	
func endInputPopup(isCancelled:bool):
	visible = false
	globalEditor.textPopupIsOpen = false
	signalBus.endTextEditPopup.emit(lineEdit.text,isCancelled)
	lineEdit.clear()

func _on_confirm_button_pressed() -> void:
	endInputPopup(false)

func _on_cancel_button_pressed() -> void:
	endInputPopup(true)
"

[sub_resource type="GDScript" id="GDScript_pee1p"]
resource_name = "playModeTopArea"
script/source = "class_name PlayModeTopArea extends HBoxContainer

var hotbarTween:Tween

func _ready() -> void:
	signalBus.startEditMode.connect(hideHud)
	signalBus.startPlayMode.connect(showHud)

func hideHud():
		hotbarTween = create_tween()
		hotbarTween.set_trans(Tween.TRANS_CUBIC)
		hotbarTween.set_ease(Tween.EASE_IN)
		hotbarTween.tween_property(self,\"offset_top\",-size.y,0.15)
func showHud():
	hotbarTween = create_tween()
	hotbarTween.set_trans(Tween.TRANS_CUBIC)
	hotbarTween.set_ease(Tween.EASE_OUT)
	hotbarTween.tween_property(self,\"offset_top\",0,0.15)
"

